H2H_DB_HOST=localhost
H2H_DB_PORT=5432
H2H_DB_DATABASE=here2help
H2H_DB_USER=here_readonly
H2H_DB_PASSWORD=help_readonly
# Valid H2H_DB_SSLMODE values: disable | require | verify-ca | verify-full.
# verify-ca / verify-full need the server's CA unless it is in Node's trust
# store; for AWS RDS set H2H_DB_SSL_CA to the PEM bundle, kept on one line
# with \n escapes like GOOGLE_PRIVATE_KEY:
# H2H_DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"
H2H_DB_SSLMODE=disable

GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_TAB=Export
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"
